#!/usr/bin/env bash

echo "Ensuring pip versions are correct"
time uv sync --frozen --extra base --extra dev --extra manipulation --extra misc --extra unitree --extra drone

echo "Running pre-commit checks"
time pre-commit run --all-files

echo "Running mypy checks"
time uv run mypy --python-version 3.10 --python-version 3.12 dimos

echo "# "
echo "# "
echo "# pytest fast"
echo "# "
echo "# "
time uv run bin/pytest-fast
